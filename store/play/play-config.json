{
  "packageName": "net.chargeledger",
  "track": "internal",
  "language": "en-US",
  "ensureDefaultLanguage": true,
  "credentials": "store/play/credentials/google-play-service-account.json",
  "aab": "build/app/outputs/bundle/release/app-release.aab",
  "listingDir": "store/shared/listing/en-US",
  "removeListingLanguages": [
    "en-GB"
  ],
  "releaseNotes": "store/shared/release/release-notes-internal.txt",
  "appDetails": {
    "defaultLanguage": "en-US",
    "contactWebsite": "https://chargeledger.net/",
    "contactEmail": "support@chargeledger.net",
    "contactPhone": "",
    "testerGoogleGroups": [
      "chargeledger@googlegroups.com"
    ]
  },
  "dataSafetyCsv": "store/play/app-content/data-safety.csv",
  "appIcon": "store/shared/assets/app-icon.png",
  "featureGraphic": "store/shared/assets/feature-graphic.png",
  "phoneScreenshots": [
    "store/shared/assets/phone-screenshots/phone-1.png",
    "store/shared/assets/phone-screenshots/phone-2.png"
  ],
  "sevenInchScreenshots": [
    "store/shared/assets/7-inch-screenshots/tablet-1.png",
    "store/shared/assets/7-inch-screenshots/tablet-2.png"
  ],
  "tenInchScreenshots": [
    "store/shared/assets/10-inch-screenshots/tablet-1.png",
    "store/shared/assets/10-inch-screenshots/tablet-2.png"
  ],
  "skipListing": false,
  "skipAppDetails": false,
  "forceUpload": false
}
